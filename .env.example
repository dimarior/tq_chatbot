# --- LLM (Ollama) ---
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=qwen3:8b

# --- Embeddings ---
# Si el tag no existe upstream, cambiar a EMBED_BACKEND=sentence-transformers
# y EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B (descarga automática desde HF).
EMBED_BACKEND=ollama
EMBED_MODEL=qwen3-embedding:0.6b
EMBED_DIMS=1024

# --- Postgres ---
DATABASE_URL=postgresql://tq:tq@localhost:5432/tq

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Incluir el origen del frontend Next.js (puerto 3000) además del API mismo.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000

# --- RAG ---
TOP_K=6
CHUNK_SIZE=600
CHUNK_OVERLAP=100
MAX_CONTEXT_CHARS=6000

# --- Scraping ---
SCRAPE_CONCURRENCY=8
SCRAPE_TIMEOUT_S=20

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=tokenhere
LANGSMITH_PROJECT=tq-chatbot
LANGSMITH_ENDPOINT=https://api.smith.langchain.com